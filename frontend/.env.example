# Backend URL (REST + Socket.IO share the same origin).
# In production set this to your Google Cloud Run URL, e.g.
# VITE_API_URL=https://softmatch-backend-xxxxx-uc.a.run.app
#
# Leave blank for local dev — the Vite proxy forwards /api and
# /socket.io to http://localhost:3001 (see vite.config.js).
VITE_API_URL=
