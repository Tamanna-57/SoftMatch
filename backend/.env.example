# ── Server ───────────────────────────────────────────────────
PORT=3001

# Allowed frontend origin(s) for CORS. Comma-separated list, or "*".
# In production set this to your Vercel URL, e.g.
# CLIENT_URL=https://softmatch.vercel.app
CLIENT_URL=http://localhost:5173

# ── MongoDB Atlas (required) ─────────────────────────────────
# Create a free cluster at https://www.mongodb.com/cloud/atlas
# then copy its connection string here. Make sure the database
# user/password are filled in and Network Access allows your IP
# (or 0.0.0.0/0 for Cloud Run).
MONGODB_URI=mongodb+srv://USER:PASSWORD@cluster.xxxxx.mongodb.net/?retryWrites=true&w=majority
MONGODB_DB=softmatch

# ── Auth ─────────────────────────────────────────────────────
# Any long random string. Generate one with:
#   node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
JWT_SECRET=change_this_to_a_long_random_string
